{
  "name": "duodushu-desktop",
  "version": "1.3.1",
  "description": "Immersive English Learning Workstation",
  "main": "dist/main.js",
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:electron",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:electron": "wait-on tcp:3000 && tsc -p electron && electron .",
    "build": "npm run build:frontend && npm run build:backend && npm run build:electron && npm run package",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && pyinstaller backend.spec --noconfirm --clean",
    "build:electron": "tsc -p electron",
    "package": "electron-builder"
  },
  "keywords": [
    "electron",
    "react",
    "next.js",
    "python",
    "fastapi"
  ],
  "author": "Duodushu Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.3.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.duodushu.desktop",
    "productName": "Duodushu",
    "publish": {
      "provider": "github",
      "owner": "gudong621",
      "repo": "duodushu-desktop"
    },
    "directories": {
      "output": "dist_app",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "frontend/out/**/*"
    ],
    "extraResources": [
      {
        "from": "backend/dist/backend",
        "to": "backend"
      }
    ],
    "extraFiles": [
      {
        "from": "resources/portable-template/data",
        "to": "data",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "fileAssociations": [
        {
          "ext": "epub",
          "name": "EPUB Document",
          "description": "EPUB 电子书"
        },
        {
          "ext": "pdf",
          "name": "PDF Document",
          "description": "PDF 文档"
        }
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/icon.icns",
      "category": "public.app-category.education",
      "fileAssociations": [
        {
          "ext": "epub",
          "name": "EPUB Document",
          "description": "EPUB 电子书",
          "mimeType": "application/epub+zip",
          "role": "Viewer"
        },
        {
          "ext": "pdf",
          "name": "PDF Document",
          "description": "PDF 文档",
          "mimeType": "application/pdf",
          "role": "Viewer"
        }
      ]
    },
    "portable": {
      "artifactName": "DuoDuShu-Desktop-Portable.exe"
    }
  },
  "dependencies": {
    "@use-gesture/react": "^10.3.1",
    "electron-serve": "^3.0.1",
    "electron-updater": "^6.8.3"
  }
}